# ============================================================
#  Maddad Backend – Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env file to version control.
# ============================================================

# SQLite database file (recommended for local development – no installation needed).
# The file maddad.db is created automatically in the backend/ folder.
#DATABASE_URL=sqlite:///./maddad.db

# To use Supabase PostgreSQL instead, comment out the line above and uncomment:
# Direct connection format:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require
# Pooler format (recommended for production/serverless):
# Replace [YOUR-REGION] with the region shown in Supabase Database connection settings (e.g. aws-0-eu-central-1).
DATABASE_URL=postgresql://postgres:Graduation%4072sproj@db.vlbjhvkqeizjafdektzx.supabase.co:5432/postgres?sslmode=require

# Secret key used to sign JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=Graduation%4072sproj

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS – comma-separated list of frontend origins, or * for development
# Example: https://my-app.netlify.app,http://localhost:5500
CORS_ORIGINS=*
