# ============================================================
#  Maddad Backend – Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env file to version control.
# ============================================================

# PostgreSQL connection URL
# Local example: postgresql://postgres:password@localhost:5432/maddad
# Supabase example: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/maddad

# Secret key used to sign JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-long-random-string

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS – comma-separated list of frontend origins, or * for development
# Example: https://my-app.netlify.app,http://localhost:5500
CORS_ORIGINS=*
